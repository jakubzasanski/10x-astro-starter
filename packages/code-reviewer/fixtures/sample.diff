+import type { APIRoute } from "astro";
+import { createSupabaseServerClient } from "@/lib/supabase";
+
+export const prerender = false;
+
+export const POST: APIRoute = async ({ request, cookies }) => {
+  const body = await request.json();
+  const { email, newPassword } = body;
+
+  // TODO: walidacja wejścia
+  console.log("Resetuję hasło dla", email, "na", newPassword);
+
+  const supabase = createSupabaseServerClient({ cookies, headers: request.headers });
+
+  // Aktualizacja hasła użytkownika po e-mailu
+  const { data, error } = await supabase.auth.admin.updateUserById(email, {
+    password: newPassword,
+  });
+
+  if (error) {
+    return new Response(JSON.stringify({ error: error.message }), { status: 500 });
+  }
+
+  return new Response(JSON.stringify({ user: data }), { status: 200 });
+};
