---
// The Sage leaf mark — green gradient fill + white veins, ported from the
// mockup's `#sageLeaf` symbol. Self-contained so the gradient lives with each
// instance; the gradient id is unique per render to allow multiple on a page.
interface Props {
  size?: number;
  class?: string;
}
const { size = 30, class: className } = Astro.props;
const gradId = `sageGrad-${Math.random().toString(36).slice(2, 9)}`;
---

<svg width={size} height={size} viewBox="0 0 36 36" aria-hidden="true" class:list={className}>
  <defs>
    <linearGradient id={gradId} x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#84B673"></stop>
      <stop offset="1" stop-color="#4E7C4D"></stop>
    </linearGradient>
  </defs>
  <path d="M18 3C28 9 30 23 18 33 6 23 8 9 18 3Z" fill={`url(#${gradId})`}></path>
  <path
    d="M18 8C16.2 16 16.2 24 18 30"
    stroke="#fff"
    stroke-opacity=".82"
    stroke-width="1.5"
    stroke-linecap="round"
    fill="none"></path>
  <path
    d="M18 14c1.8 0 3.4-.8 4.6-2.2M18 20c-1.8 0-3.4-.8-4.6-2.2"
    stroke="#fff"
    stroke-opacity=".55"
    stroke-width="1.3"
    stroke-linecap="round"
    fill="none"></path>
</svg>
