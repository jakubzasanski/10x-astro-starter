---
import Layout from "@/layouts/Layout.astro";
import ResetPasswordForm from "@/components/auth/ResetPasswordForm";
import { createClient } from "@/lib/supabase";

const error = Astro.url.searchParams.get("error");
const tokenHash = Astro.url.searchParams.get("token_hash");
const type = Astro.url.searchParams.get("type");

// Establish the recovery session from the emailed link's token_hash. The customized recovery template
// (supabase/templates/recovery.html) links straight here with `token_hash` + `type=recovery`, so the
// server can mint the recovery session into cookies via verifyOtp — no PKCE round-trip through GoTrue.
let showForm = false;

if (tokenHash && type === "recovery") {
  const supabase = createClient(Astro.request.headers, Astro.cookies);
  if (supabase) {
    const { error: verifyError } = await supabase.auth.verifyOtp({ type: "recovery", token_hash: tokenHash });
    showForm = !verifyError;
  }
} else if (error) {
  // Post-POST relay (validation error). Re-render the form only if the recovery session minted on the
  // first visit is still active; if it has since expired, fall through to the expired panel rather than
  // looping the user on a form whose updateUser will keep failing.
  const supabase = createClient(Astro.request.headers, Astro.cookies);
  if (supabase) {
    const {
      data: { user },
    } = await supabase.auth.getUser();
    showForm = Boolean(user);
  }
}
---

<Layout title="Reset password">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    {
      showForm ? (
        <div class="w-full max-w-sm rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
          <h1 class="mb-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-center text-2xl font-bold text-transparent">
            Set a new password
          </h1>
          <p class="mb-6 text-center text-sm text-blue-100/60">Choose a new password for your account.</p>
          <ResetPasswordForm serverError={error} client:load />
        </div>
      ) : (
        <div class="w-full max-w-sm rounded-2xl border border-white/10 bg-white/10 p-8 text-center text-white backdrop-blur-xl">
          <div class="mb-4 text-5xl">⏳</div>
          <h1 class="mb-3 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-2xl font-bold text-transparent">
            This reset link is invalid or has expired
          </h1>
          <p class="mb-6 text-blue-100/80">
            Reset links can only be used once and expire after a short time. Request a new one to continue.
          </p>
          <a href="/auth/forgot-password" class="text-sm text-purple-300 hover:underline">
            Request a new link
          </a>
        </div>
      )
    }
  </div>
</Layout>
