---
import Layout from "@/layouts/Layout.astro";
import ForgotPasswordForm from "@/components/auth/ForgotPasswordForm";

const error = Astro.url.searchParams.get("error");
const sent = Astro.url.searchParams.get("sent");
---

<Layout title="Forgot password">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    {
      sent ? (
        <div class="w-full max-w-sm rounded-2xl border border-white/10 bg-white/10 p-8 text-center text-white backdrop-blur-xl">
          <div class="mb-4 text-5xl">📧</div>
          <h1 class="mb-3 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-2xl font-bold text-transparent">
            Check your email
          </h1>
          <p class="mb-6 text-blue-100/80">
            If an account exists for that email, we've sent a password-reset link. Check your inbox.
          </p>
          <a href="/auth/signin" class="text-sm text-purple-300 hover:underline">
            Back to sign in
          </a>
        </div>
      ) : (
        <div class="w-full max-w-sm rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
          <h1 class="mb-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-center text-2xl font-bold text-transparent">
            Forgot password
          </h1>
          <p class="mb-6 text-center text-sm text-blue-100/60">
            Enter your email and we'll send you a link to reset your password.
          </p>
          <ForgotPasswordForm serverError={error} client:load />
          <p class="mt-4 text-center text-sm text-blue-100/60">
            Remember your password?{" "}
            <a href="/auth/signin" class="text-purple-300 hover:underline">
              Sign in
            </a>
          </p>
        </div>
      )
    }
  </div>
</Layout>
