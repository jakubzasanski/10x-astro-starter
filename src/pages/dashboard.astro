---
import AppLayout from "@/layouts/AppLayout.astro";
import { createClient } from "@/lib/supabase";

const { user } = Astro.locals;

// Count cards due for review now (due <= now), RLS-scoped to the signed-in user, to drive the
// review entry point. head:true fetches only the count, not the rows.
let dueCount = 0;
const supabase = createClient(Astro.request.headers, Astro.cookies);
if (supabase) {
  const { count } = await supabase
    .from("flashcards")
    .select("id", { count: "exact", head: true })
    .lte("due", new Date().toISOString());
  dueCount = count ?? 0;
}
---

<AppLayout title="Dashboard">
  <div class="page-head">
    <h1>Dashboard</h1>
    <p>Welcome, {user?.email}</p>
  </div>

  <div class="dash-actions">
    {
      dueCount > 0 ? (
        <a class="btn btn-primary" href="/review">
          Review {dueCount} {dueCount === 1 ? "card" : "cards"} due
        </a>
      ) : (
        <p class="dash-empty">No cards due for review right now.</p>
      )
    }
    <a class="btn btn-ghost" href="/cards">Browse your deck</a>
    <a class="btn btn-ghost" href="/cards/new">Add a card manually</a>
    <a class="btn btn-ghost" href="/generate">Generate flashcards</a>
  </div>
</AppLayout>

<style>
  .dash-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }
  .dash-empty {
    color: var(--text-soft);
    margin: 0;
    font-size: 0.95rem;
  }
</style>
