---
import AppLayout from "@/layouts/AppLayout.astro";
import GeneratorView from "@/components/generation/GeneratorView";
import { t } from "@/i18n";

// Protected by middleware (PROTECTED_ROUTES); unauthenticated users are redirected to /auth/signin.
const { locale } = Astro.locals;
---

<AppLayout title="Generate flashcards">
  <div class="page-head">
    <h1>{t(locale, "gen.title")}</h1>
    <p>{t(locale, "gen.sub")}</p>
  </div>
  <GeneratorView locale={locale} client:load />
</AppLayout>
